# ── Dharma CMS Backend - Environment Variables ───  
# Copy this file to .env and fill in the values.  
# NEVER commit .env to version control.  
  
# ── Environment ──  
APP_ENV=development  
PORT=8000  
  
# ── Security ──  
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"  
SECRET_KEY=CHANGE-ME-in-production-use-openssl-rand-hex-32  
  
# Comma-separated list of allowed CORS origins  
# For local Flutter dev, typically http://localhost:5555  
CORS_ORIGINS=["http://localhost:5555","http://localhost:8000"]  
  
# Comma-separated list of allowed hostnames (production only)  
# Set to your domain in production, e.g. ["api.dharma-cms.example.com"]  
ALLOWED_HOSTS=["*"]  
  
# Max upload size in MB (applies to all request bodies)  
MAX_UPLOAD_SIZE_MB=10  
  
# ── Database ──  
# Default: SQLite (zero-install local dev)  
# Production: postgresql+asyncpg://USER:PASSWORD@HOST:PORT/DBNAME  
DATABASE_URL=sqlite+aiosqlite:///dev.db  
  
# ── Firebase (for token verification only) ──  
# Path to your Firebase service account JSON file  
# Download from Firebase Console > Project Settings > Service Accounts  
# Leave empty to use Application Default Credentials (Cloud Run, GCE)  
FIREBASE_CREDENTIALS=  
  
# ── AI Service (old backend / AI microservice) ──  
AI_SERVICE_URL=https://fastapi-app-335340524683.asia-south1.run.app 
